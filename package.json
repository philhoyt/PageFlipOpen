{
  "name": "pageflipopen",
  "version": "0.2.0",
  "description": "Self-contained JavaScript class that renders a PDF as an interactive 3D flipbook in the browser.",
  "license": "MIT",
  "type": "module",
  "main": "dist/pageflipopen.iife.js",
  "module": "dist/pageflipopen.js",
  "exports": {
    ".": {
      "import": "./dist/pageflipopen.js",
      "default": "./dist/pageflipopen.iife.js"
    },
    "./pageflipopen.css": "./dist/pageflipopen.css"
  },
  "files": [
    "dist/pageflipopen.js",
    "dist/pageflipopen.iife.js",
    "dist/pageflipopen.min.js",
    "dist/pageflipopen.css",
    "dist/pdf.worker.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --dev",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.5.1",
    "gsap": "^3.12.5",
    "hammerjs": "^2.0.8",
    "pdfjs-dist": "^4.4.168",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.23.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  }
}
